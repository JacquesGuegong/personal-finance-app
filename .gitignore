# ── Compiled output ───────────────────────────────────────────────────────────
*.class
build/
out/

# ── Gradle ────────────────────────────────────────────────────────────────────
.gradle/
gradle-app.setting
!gradle-wrapper.jar
!gradle-wrapper.properties

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
*.iml
.vscode/
*.swp
.metals/
bin/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Secrets — NEVER commit these ─────────────────────────────────────────────
.env
.env.*
# …but DO commit the template (it contains no real secrets):
!.env.example
application-local.properties
application-secret.properties

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Archives ──────────────────────────────────────────────────────────────────
*.jar
# Exception: the Gradle wrapper jar MUST be committed so ./gradlew works on a
# fresh checkout (e.g. CI), where it can't be downloaded ahead of time.
!gradle/wrapper/gradle-wrapper.jar
*.war
*.zip
*.tar.gz
